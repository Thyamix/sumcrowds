{
  "name": "SumcrowdsMobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "generate-config": "node ../scripts/generate-mobile-config.js",
    "generate-config:dev": "node ../scripts/generate-mobile-config.js dev",
    "generate-config:staging": "node ../scripts/generate-mobile-config.js staging",
    "generate-config:prod": "node ../scripts/generate-mobile-config.js prod",
    "preandroid": "npm run generate-config:prod",
    "android": "react-native run-android",
    "android:dev": "npm run generate-config:dev && react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native/new-app-screen": "0.83.1",
    "@react-navigation/native": "^7.1.26",
    "@react-navigation/native-stack": "^7.9.0",
    "i18next": "^25.7.4",
    "react": "19.2.0",
    "react-i18next": "^16.5.2",
    "react-native": "0.83.1",
    "react-native-blob-util": "^0.24.6",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.19.0",
    "react-native-share": "^12.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.83.1",
    "@react-native/eslint-config": "0.83.1",
    "@react-native/metro-config": "0.83.1",
    "@react-native/typescript-config": "0.83.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.0",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
