# Sumcrowds Environment Variables Template
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in values

# Database connection URL (required)
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://sumcrowds:PASSWORD@postgres_dev:5432/sumcrowds?sslmode=disable

# Deployment mode - set to "docker" when running in containers
APP_DEPLOY=docker

# Future secrets can be added here:
# API_SECRET_KEY=
# JWT_SECRET=
